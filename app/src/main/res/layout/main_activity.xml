<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    tools:context=".activities.MainActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- LOGO CARD -->
        <RelativeLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/alt_logo"
                tools:src="@drawable/ic_logo" />

            <ProgressBar
                android:id="@+id/progress_circle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:indeterminate="true"
                android:visibility="gone"
                tools:visibility="visible" />

        </RelativeLayout>

        <!-- APP NAME -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="TerorismePS"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- STATUS -->
        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            tools:text="Disconnected" />

        <!-- BUTTON -->
        <Button
            android:id="@+id/status_button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_modern"
            android:text="START"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- INFO CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/mode_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E2E8F0"
                android:textSize="14sp"
                android:gravity="center"
                tools:text="VPN Mode Active" />

            <TextView
                android:id="@+id/proxy_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#38BDF8"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="6dp"
                tools:text="127.0.0.1:8085" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

        <!-- FOOTER -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/links"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Links"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:text="TerorismePS © 2026" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
